rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAllowedGridSize(gridSize) {
      return gridSize == 3
        || gridSize == 4
        || gridSize == 5;
    }

    function isValidCoordinate(coordinate) {
      return coordinate is string
        && coordinate.matches('^[A-E][1-5]$');
    }

    function isValidNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 20;
    }

    function isValidJoinRequestType(requestType) {
      return requestType == 'join'
        || requestType == 'rejoin';
    }

    function tablePath(tableCode) {
      return /databases/$(database)/documents/tables/$(tableCode);
    }

    function participantPath(
      tableCode,
      participantUid
    ) {
      return /databases/$(database)/documents/tables/$(tableCode)/participants/$(participantUid);
    }

    function playerPath(
      tableCode,
      playerUid
    ) {
      return /databases/$(database)/documents/tables/$(tableCode)/players/$(playerUid);
    }

    function joinRequestPath(
      tableCode,
      requestUid
    ) {
      return /databases/$(database)/documents/tables/$(tableCode)/joinRequests/$(requestUid);
    }

    function setupBoardPath(tableCode) {
      return /databases/$(database)/documents/tables/$(tableCode)/setup/board;
    }

    function gameBoardPath(tableCode) {
      return /databases/$(database)/documents/tables/$(tableCode)/game/board;
    }

    function gameStatePath(tableCode) {
      return /databases/$(database)/documents/tables/$(tableCode)/game/state;
    }

    function isActiveParticipant(
      tableCode,
      participantUid
    ) {
      return exists(
          participantPath(
            tableCode,
            participantUid
          )
        )
        && get(
          participantPath(
            tableCode,
            participantUid
          )
        ).data.status == 'active';
    }

    function isCurrentHost(tableCode) {
      return isAuthenticated()
        && get(
          tablePath(tableCode)
        ).data.hostUid == request.auth.uid
        && isActiveParticipant(
          tableCode,
          request.auth.uid
        );
    }

    function isFinishedTableHost(
      tableCode
    ) {
      return isCurrentHost(tableCode)
        && get(
          tablePath(tableCode)
        ).data.status == 'finished';
    }

    function isLobby(tableCode) {
      return get(
        tablePath(tableCode)
      ).data.status == 'lobby';
    }

    function hasValidPublicPlayerAfter(
      tableCode,
      participantUid
    ) {
      return existsAfter(
          playerPath(
            tableCode,
            participantUid
          )
        )
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.uid == participantUid
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.nickname
          == getAfter(
            participantPath(
              tableCode,
              participantUid
            )
          ).data.nickname
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.role
          == getAfter(
            participantPath(
              tableCode,
              participantUid
            )
          ).data.role
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.status
          == getAfter(
            participantPath(
              tableCode,
              participantUid
            )
          ).data.status;
    }

    function isCreatingHost(
      tableCode,
      participantUid
    ) {
      return request.resource.data.role
          == 'host'
        && getAfter(
          tablePath(tableCode)
        ).data.hostUid == participantUid;
    }

    function isJoiningLobby(
      tableCode
    ) {
      return request.resource.data.role
          == 'player'
        && exists(
          tablePath(tableCode)
        )
        && get(
          tablePath(tableCode)
        ).data.status == 'lobby';
    }

    function isValidNewJoinRequest(
      tableCode,
      requestUid
    ) {
      return !exists(
          participantPath(
            tableCode,
            requestUid
          )
        )
        && !exists(
          playerPath(
            tableCode,
            requestUid
          )
        );
    }

    function isValidRejoinRequest(
      tableCode,
      requestUid
    ) {
      return exists(
          participantPath(
            tableCode,
            requestUid
          )
        )
        && exists(
          playerPath(
            tableCode,
            requestUid
          )
        )
        && get(
          participantPath(
            tableCode,
            requestUid
          )
        ).data.uid == requestUid
        && get(
          participantPath(
            tableCode,
            requestUid
          )
        ).data.role == 'player'
        && get(
          participantPath(
            tableCode,
            requestUid
          )
        ).data.status == 'left'
        && get(
          participantPath(
            tableCode,
            requestUid
          )
        ).data.currentCoordinate
          == null
        && get(
          playerPath(
            tableCode,
            requestUid
          )
        ).data.uid == requestUid
        && get(
          playerPath(
            tableCode,
            requestUid
          )
        ).data.role == 'player'
        && get(
          playerPath(
            tableCode,
            requestUid
          )
        ).data.status == 'left';
    }

    function hasLeftPublicPlayerAfter(
      tableCode,
      participantUid
    ) {
      return existsAfter(
          playerPath(
            tableCode,
            participantUid
          )
        )
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.uid == participantUid
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.status == 'left'
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.nickname
          == getAfter(
            participantPath(
              tableCode,
              participantUid
            )
          ).data.nickname
        && getAfter(
          playerPath(
            tableCode,
            participantUid
          )
        ).data.role
          == getAfter(
            participantPath(
              tableCode,
              participantUid
            )
          ).data.role;
    }

    function hasReturnedCoordinateAfter(
      tableCode,
      participantUid
    ) {
      return getAfter(
          gameStatePath(tableCode)
        ).data.availableCoordinates
          == get(
            gameStatePath(tableCode)
          ).data.availableCoordinates.concat([
            get(
              participantPath(
                tableCode,
                participantUid
              )
            ).data.currentCoordinate
          ])
        && getAfter(
          gameStatePath(tableCode)
        ).data.discardedCoordinates
          == get(
            gameStatePath(tableCode)
          ).data.discardedCoordinates
        && getAfter(
          gameStatePath(tableCode)
        ).data.remainingCoordinateCount
          == get(
            gameStatePath(tableCode)
          ).data.remainingCoordinateCount;
    }

    function isLeavingOwnParticipant(
      tableCode,
      participantUid
    ) {
      return participantUid
          == request.auth.uid
        && resource.data.uid
          == request.auth.uid
        && resource.data.role
          != 'host'
        && get(
          tablePath(tableCode)
        ).data.hostUid != request.auth.uid
        && resource.data.status
          == 'active'
        && request.resource.data.status
          == 'left'
        && request.resource.data.currentCoordinate
          == null
        && request.resource.data.failedCoordinates
          == resource.data.failedCoordinates
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'currentCoordinate'
          ])
        && hasLeftPublicPlayerAfter(
          tableCode,
          participantUid
        )
        && (
          (
            get(
              tablePath(tableCode)
            ).data.status == 'lobby'
            && resource.data.currentCoordinate
              == null
          )
          ||
          (
            get(
              tablePath(tableCode)
            ).data.status == 'playing'
            && (
              resource.data.currentCoordinate
                == null
              ||
              (
                isValidCoordinate(
                  resource.data.currentCoordinate
                )
                && hasReturnedCoordinateAfter(
                  tableCode,
                  participantUid
                )
              )
            )
          )
        );
    }

    function hasValidBoardPreparation(
      tableCode
    ) {
      return request.resource.data.keys()
          .hasOnly([
            'gridSize',
            'columnWords',
            'rowWords',
            'updatedAt'
          ])
        && request.resource.data.gridSize
          == get(
            tablePath(tableCode)
          ).data.gridSize
        && request.resource.data.columnWords
          is list
        && request.resource.data.rowWords
          is list
        && request.resource.data.columnWords
          .size()
          == request.resource.data.gridSize
        && request.resource.data.rowWords
          .size()
          == request.resource.data.gridSize
        && request.resource.data.updatedAt
          == request.time;
    }

    function isStartingGame() {
      return resource.data.status
          == 'lobby'
        && request.resource.data.status
          == 'playing'
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'startedAt'
          ])
        && request.resource.data.startedAt
          == request.time;
    }

    function isFinishingGame(
      tableCode
    ) {
      return resource.data.status
          == 'playing'
        && request.resource.data.status
          == 'finished'
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'finishedAt',
            'finishReason'
          ])
        && request.resource.data.finishedAt
          == request.time
        && (
          (
            request.resource.data.finishReason
              == 'completed'
            && existsAfter(
              gameStatePath(tableCode)
            )
            && getAfter(
              gameStatePath(tableCode)
            ).data.remainingCoordinateCount
              == 0
          )
          ||
          (
            request.resource.data.finishReason
              == 'manual'
            && request.auth.uid
              == resource.data.hostUid
            && isActiveParticipant(
              tableCode,
              request.auth.uid
            )
          )
        );
    }

    /*
     * Lectura puntual del registro público de un solicitante.
     *
     * Se utiliza durante la aprobación para comprobar si ese UID
     * ya tuvo participación en la mesa. No concede acceso al documento
     * privado de participants.
     */
    match /tables/{tableCode}/players/{playerUid} {
      allow get: if isAuthenticated()
        && isCurrentHost(tableCode)
        && get(
          tablePath(tableCode)
        ).data.status == 'playing'
        && exists(
          joinRequestPath(
            tableCode,
            playerUid
          )
        )
        && get(
          joinRequestPath(
            tableCode,
            playerUid
          )
        ).data.status == 'pending';
    }

    match /tables/{tableCode} {
      allow create: if isAuthenticated()
        && request.resource.data.keys()
          .hasOnly([
            'code',
            'gridSize',
            'hostUid',
            'status',
            'createdAt'
          ])
        && request.resource.data.code
          == tableCode
        && request.resource.data.hostUid
          == request.auth.uid
        && request.resource.data.status
          == 'lobby'
        && request.resource.data.createdAt
          == request.time
        && isAllowedGridSize(
          request.resource.data.gridSize
        )
        && existsAfter(
          participantPath(
            tableCode,
            request.auth.uid
          )
        )
        && getAfter(
          participantPath(
            tableCode,
            request.auth.uid
          )
        ).data.uid == request.auth.uid
        && getAfter(
          participantPath(
            tableCode,
            request.auth.uid
          )
        ).data.role == 'host'
        && hasValidPublicPlayerAfter(
          tableCode,
          request.auth.uid
        );

      allow get: if isAuthenticated();

      allow update: if isAuthenticated()
        && isActiveParticipant(
          tableCode,
          request.auth.uid
        )
        && (
          (
            request.auth.uid
              == resource.data.hostUid
            && resource.data.status
              == 'lobby'
            && request.resource.data
              .diff(resource.data)
              .affectedKeys()
              .hasOnly([
                'gridSize'
              ])
            && isAllowedGridSize(
              request.resource.data.gridSize
            )
          )
          ||
          (
            request.auth.uid
              == resource.data.hostUid
            && isStartingGame()
            && existsAfter(
              gameBoardPath(tableCode)
            )
            && existsAfter(
              gameStatePath(tableCode)
            )
          )
          ||
          isFinishingGame(tableCode)
        );

      allow list: if false;

      allow delete: if
        isFinishedTableHost(tableCode);

      match /participants/{participantUid} {
        allow create: if isAuthenticated()
          && request.resource.data.keys()
            .hasOnly([
              'uid',
              'nickname',
              'role',
              'status',
              'currentCoordinate',
              'failedCoordinates',
              'joinedAt'
            ])
          && request.resource.data.uid
            == participantUid
          && isValidNickname(
            request.resource.data.nickname
          )
          && request.resource.data.status
            == 'active'
          && request.resource.data.failedCoordinates
            is list
          && request.resource.data.failedCoordinates
            .size() == 0
          && request.resource.data.joinedAt
            == request.time
          && (
            (
              participantUid
                == request.auth.uid
              && request.resource.data.currentCoordinate
                == null
              && (
                isCreatingHost(
                  tableCode,
                  participantUid
                )
                || isJoiningLobby(
                  tableCode
                )
              )
            )
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && request.resource.data.role
                == 'player'
              && isValidCoordinate(
                request.resource.data.currentCoordinate
              )
              && exists(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              )
              && get(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              ).data.status == 'pending'
              && getAfter(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              ).data.status == 'approved'
              && request.resource.data.nickname
                == get(
                  joinRequestPath(
                    tableCode,
                    participantUid
                  )
                ).data.nickname
            )
          )
          && hasValidPublicPlayerAfter(
            tableCode,
            participantUid
          );

        allow get: if isAuthenticated()
          && (
            participantUid
              == request.auth.uid
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'lobby'
            )
          );

        allow update: if isAuthenticated()
          && (
            (
              participantUid
                == request.auth.uid
              && resource.data.uid
                == request.auth.uid
              && resource.data.status
                == 'left'
              && get(
                tablePath(tableCode)
              ).data.status == 'lobby'
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'nickname',
                  'status'
                ])
              && isValidNickname(
                request.resource.data.nickname
              )
              && request.resource.data.status
                == 'active'
              && hasValidPublicPlayerAfter(
                tableCode,
                participantUid
              )
            )
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'lobby'
              && getAfter(
                tablePath(tableCode)
              ).data.status == 'playing'
              && resource.data.status
                == 'active'
              && resource.data.currentCoordinate
                == null
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'currentCoordinate'
                ])
              && isValidCoordinate(
                request.resource.data.currentCoordinate
              )
            )
            ||
            (
              participantUid
                == request.auth.uid
              && resource.data.uid
                == request.auth.uid
              && resource.data.status
                == 'active'
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && isValidCoordinate(
                resource.data.currentCoordinate
              )
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'currentCoordinate',
                  'failedCoordinates'
                ])
              && request.resource.data.uid
                == resource.data.uid
              && request.resource.data.nickname
                == resource.data.nickname
              && request.resource.data.role
                == resource.data.role
              && request.resource.data.status
                == resource.data.status
              && request.resource.data.joinedAt
                == resource.data.joinedAt
              && (
                request.resource.data.currentCoordinate
                  == null
                || isValidCoordinate(
                  request.resource.data.currentCoordinate
                )
              )
              && request.resource.data.failedCoordinates
                is list
              && (
                request.resource.data.failedCoordinates
                  == resource.data.failedCoordinates
                ||
                request.resource.data.failedCoordinates
                  == resource.data.failedCoordinates.concat([
                    resource.data.currentCoordinate
                  ])
              )
            )
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && resource.data.uid
                == participantUid
              && resource.data.role
                == 'player'
              && resource.data.status
                == 'left'
              && resource.data.currentCoordinate
                == null
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'nickname',
                  'status',
                  'currentCoordinate'
                ])
              && request.resource.data.uid
                == resource.data.uid
              && request.resource.data.role
                == resource.data.role
              && request.resource.data.joinedAt
                == resource.data.joinedAt
              && request.resource.data.failedCoordinates
                == resource.data.failedCoordinates
              && isValidNickname(
                request.resource.data.nickname
              )
              && request.resource.data.status
                == 'active'
              && isValidCoordinate(
                request.resource.data.currentCoordinate
              )
              && exists(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              )
              && get(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              ).data.type == 'rejoin'
              && get(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              ).data.status == 'pending'
              && getAfter(
                joinRequestPath(
                  tableCode,
                  participantUid
                )
              ).data.status == 'approved'
              && request.resource.data.nickname
                == get(
                  joinRequestPath(
                    tableCode,
                    participantUid
                  )
                ).data.nickname
              && hasValidPublicPlayerAfter(
                tableCode,
                participantUid
              )
            )
            ||
            isLeavingOwnParticipant(
              tableCode,
              participantUid
            )
          );

        allow list: if
          isFinishedTableHost(tableCode);

        allow delete: if
          isFinishedTableHost(tableCode);
      }

      match /players/{playerUid} {
        allow create: if isAuthenticated()
          && request.resource.data.keys()
            .hasOnly([
              'uid',
              'nickname',
              'role',
              'status',
              'joinedAt'
            ])
          && request.resource.data.uid
            == playerUid
          && isValidNickname(
            request.resource.data.nickname
          )
          && (
            request.resource.data.role
              == 'host'
            || request.resource.data.role
              == 'player'
          )
          && request.resource.data.status
            == 'active'
          && request.resource.data.joinedAt
            == request.time
          && existsAfter(
            participantPath(
              tableCode,
              playerUid
            )
          )
          && getAfter(
            participantPath(
              tableCode,
              playerUid
            )
          ).data.uid == playerUid
          && getAfter(
            participantPath(
              tableCode,
              playerUid
            )
          ).data.nickname
            == request.resource.data.nickname
          && getAfter(
            participantPath(
              tableCode,
              playerUid
            )
          ).data.role
            == request.resource.data.role
          && getAfter(
            participantPath(
              tableCode,
              playerUid
            )
          ).data.status
            == request.resource.data.status
          && (
            playerUid
              == request.auth.uid
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && exists(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              )
              && get(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'pending'
              && getAfter(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'approved'
            )
          );

        allow update: if isAuthenticated()
          && (
            (
              playerUid
                == request.auth.uid
              && resource.data.status
                == 'left'
              && get(
                tablePath(tableCode)
              ).data.status == 'lobby'
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'nickname',
                  'status'
                ])
              && isValidNickname(
                request.resource.data.nickname
              )
              && request.resource.data.status
                == 'active'
              && existsAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              )
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.nickname
                == request.resource.data.nickname
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.status
                == request.resource.data.status
            )
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && resource.data.uid
                == playerUid
              && resource.data.role
                == 'player'
              && resource.data.status
                == 'left'
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'nickname',
                  'status'
                ])
              && request.resource.data.uid
                == resource.data.uid
              && request.resource.data.role
                == resource.data.role
              && request.resource.data.joinedAt
                == resource.data.joinedAt
              && isValidNickname(
                request.resource.data.nickname
              )
              && request.resource.data.status
                == 'active'
              && exists(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              )
              && get(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              ).data.type == 'rejoin'
              && get(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'pending'
              && getAfter(
                joinRequestPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'approved'
              && request.resource.data.nickname
                == get(
                  joinRequestPath(
                    tableCode,
                    playerUid
                  )
                ).data.nickname
              && existsAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              )
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'active'
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.nickname
                == request.resource.data.nickname
            )
            ||
            (
              playerUid
                == request.auth.uid
              && resource.data.status
                == 'active'
              && resource.data.role
                != 'host'
              && get(
                tablePath(tableCode)
              ).data.hostUid
                != request.auth.uid
              && (
                get(
                  tablePath(tableCode)
                ).data.status == 'lobby'
                || get(
                  tablePath(tableCode)
                ).data.status == 'playing'
              )
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'status'
                ])
              && request.resource.data.status
                == 'left'
              && existsAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              )
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.status == 'left'
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.nickname
                == request.resource.data.nickname
              && getAfter(
                participantPath(
                  tableCode,
                  playerUid
                )
              ).data.role
                == request.resource.data.role
            )
          );

        allow get: if isAuthenticated()
          && playerUid
            == request.auth.uid;

        allow list: if isAuthenticated()
          && isActiveParticipant(
            tableCode,
            request.auth.uid
          );

        allow delete: if
          isFinishedTableHost(tableCode);
      }

      match /joinRequests/{requestUid} {
        allow create: if isAuthenticated()
          && requestUid
            == request.auth.uid
          && exists(
            tablePath(tableCode)
          )
          && get(
            tablePath(tableCode)
          ).data.status == 'playing'
          && request.resource.data.keys()
            .hasOnly([
              'uid',
              'nickname',
              'type',
              'status',
              'requestedAt'
            ])
          && request.resource.data.uid
            == request.auth.uid
          && isValidNickname(
            request.resource.data.nickname
          )
          && request.resource.data.status
            == 'pending'
          && request.resource.data.requestedAt
            == request.time
          && (
            (
              request.resource.data.type
                == 'join'
              && isValidNewJoinRequest(
                tableCode,
                requestUid
              )
            )
            ||
            (
              request.resource.data.type
                == 'rejoin'
              && isValidRejoinRequest(
                tableCode,
                requestUid
              )
            )
          );

        allow get: if isAuthenticated()
          && (
            requestUid
              == request.auth.uid
            || isCurrentHost(tableCode)
          );

        allow list: if
          isCurrentHost(tableCode);

        allow update: if isAuthenticated()
          && (
            (
              requestUid
                == request.auth.uid
              && exists(
                tablePath(tableCode)
              )
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && request.resource.data.keys()
                .hasOnly([
                  'uid',
                  'nickname',
                  'type',
                  'status',
                  'requestedAt'
                ])
              && request.resource.data.uid
                == request.auth.uid
              && isValidNickname(
                request.resource.data.nickname
              )
              && request.resource.data.status
                == 'pending'
              && request.resource.data.requestedAt
                == request.time
              && (
                (
                  request.resource.data.type
                    == 'join'
                  && isValidNewJoinRequest(
                    tableCode,
                    requestUid
                  )
                )
                ||
                (
                  request.resource.data.type
                    == 'rejoin'
                  && isValidRejoinRequest(
                    tableCode,
                    requestUid
                  )
                )
              )
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'nickname',
                  'type',
                  'status',
                  'requestedAt',
                  'resolvedAt',
                  'resolvedBy'
                ])
            )
            ||
            (
              isCurrentHost(tableCode)
              && get(
                tablePath(tableCode)
              ).data.status == 'playing'
              && resource.data.uid
                == requestUid
              && resource.data.status
                == 'pending'
              && isValidJoinRequestType(
                resource.data.type
              )
              && request.resource.data.keys()
                .hasOnly([
                  'uid',
                  'nickname',
                  'type',
                  'status',
                  'requestedAt',
                  'resolvedAt',
                  'resolvedBy'
                ])
              && request.resource.data.uid
                == resource.data.uid
              && request.resource.data.nickname
                == resource.data.nickname
              && request.resource.data.type
                == resource.data.type
              && request.resource.data.requestedAt
                == resource.data.requestedAt
              && (
                request.resource.data.status
                  == 'rejected'
                ||
                (
                  resource.data.type
                    == 'join'
                  && request.resource.data.status
                    == 'approved'
                  && !exists(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  )
                  && !exists(
                    playerPath(
                      tableCode,
                      requestUid
                    )
                  )
                  && existsAfter(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  )
                  && existsAfter(
                    playerPath(
                      tableCode,
                      requestUid
                    )
                  )
                  && get(
                    gameStatePath(tableCode)
                  ).data.availableCoordinates
                    .size() > 0
                  && getAfter(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  ).data.currentCoordinate
                    == get(
                      gameStatePath(tableCode)
                    ).data.availableCoordinates[0]
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.availableCoordinates
                    == get(
                      gameStatePath(tableCode)
                    ).data.availableCoordinates.removeAll([
                      get(
                        gameStatePath(tableCode)
                      ).data.availableCoordinates[0]
                    ])
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.discardedCoordinates
                    == get(
                      gameStatePath(tableCode)
                    ).data.discardedCoordinates
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.remainingCoordinateCount
                    == get(
                      gameStatePath(tableCode)
                    ).data.remainingCoordinateCount
                )
                ||
                (
                  resource.data.type
                    == 'rejoin'
                  && request.resource.data.status
                    == 'approved'
                  && isValidRejoinRequest(
                    tableCode,
                    requestUid
                  )
                  && getAfter(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  ).data.status == 'active'
                  && getAfter(
                    playerPath(
                      tableCode,
                      requestUid
                    )
                  ).data.status == 'active'
                  && get(
                    gameStatePath(tableCode)
                  ).data.availableCoordinates
                    .size() > 0
                  && getAfter(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  ).data.currentCoordinate
                    == get(
                      gameStatePath(tableCode)
                    ).data.availableCoordinates[0]
                  && getAfter(
                    participantPath(
                      tableCode,
                      requestUid
                    )
                  ).data.failedCoordinates
                    == get(
                      participantPath(
                        tableCode,
                        requestUid
                      )
                    ).data.failedCoordinates
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.availableCoordinates
                    == get(
                      gameStatePath(tableCode)
                    ).data.availableCoordinates.removeAll([
                      get(
                        gameStatePath(tableCode)
                      ).data.availableCoordinates[0]
                    ])
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.discardedCoordinates
                    == get(
                      gameStatePath(tableCode)
                    ).data.discardedCoordinates
                  && getAfter(
                    gameStatePath(tableCode)
                  ).data.remainingCoordinateCount
                    == get(
                      gameStatePath(tableCode)
                    ).data.remainingCoordinateCount
                )
              )
              && request.resource.data.resolvedAt
                == request.time
              && request.resource.data.resolvedBy
                == request.auth.uid
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'status',
                  'resolvedAt',
                  'resolvedBy'
                ])
            )
          );

        allow delete: if
          isFinishedTableHost(tableCode);
      }

      match /setup/{setupDocumentId} {
        allow get: if
          setupDocumentId == 'board'
          && isCurrentHost(tableCode);

        allow create, update: if
          setupDocumentId == 'board'
          && isCurrentHost(tableCode)
          && isLobby(tableCode)
          && hasValidBoardPreparation(
            tableCode
          );

        allow list: if false;

        allow delete: if
          isFinishedTableHost(tableCode);
      }

      match /game/{gameDocumentId} {
        allow create: if
          isCurrentHost(tableCode)
          && get(
            tablePath(tableCode)
          ).data.status == 'lobby'
          && getAfter(
            tablePath(tableCode)
          ).data.status == 'playing'
          && request.resource.data.startedAt
            == request.time
          && (
            (
              gameDocumentId == 'board'
              && request.resource.data.keys()
                .hasOnly([
                  'gridSize',
                  'columnWords',
                  'rowWords',
                  'revealedCoordinates',
                  'startedAt'
                ])
              && request.resource.data.gridSize
                == get(
                  tablePath(tableCode)
                ).data.gridSize
              && request.resource.data.columnWords
                == get(
                  setupBoardPath(tableCode)
                ).data.columnWords
              && request.resource.data.rowWords
                == get(
                  setupBoardPath(tableCode)
                ).data.rowWords
              && request.resource.data.revealedCoordinates
                is list
              && request.resource.data.revealedCoordinates
                .size() == 0
            )
            ||
            (
              gameDocumentId == 'state'
              && request.resource.data.keys()
                .hasOnly([
                  'gridSize',
                  'availableCoordinates',
                  'discardedCoordinates',
                  'remainingCoordinateCount',
                  'startedAt'
                ])
              && request.resource.data.gridSize
                == get(
                  tablePath(tableCode)
                ).data.gridSize
              && request.resource.data.availableCoordinates
                is list
              && request.resource.data.discardedCoordinates
                is list
              && request.resource.data.discardedCoordinates
                .size() == 0
              && request.resource.data.remainingCoordinateCount
                == (
                  request.resource.data.gridSize
                  * request.resource.data.gridSize
                )
            )
          );

        allow get: if isAuthenticated()
          && (
            (
              gameDocumentId == 'board'
              && isActiveParticipant(
                tableCode,
                request.auth.uid
              )
            )
            ||
            (
              gameDocumentId == 'state'
              && isActiveParticipant(
                tableCode,
                request.auth.uid
              )
            )
          );

        allow update: if isAuthenticated()
          && isActiveParticipant(
            tableCode,
            request.auth.uid
          )
          && get(
            tablePath(tableCode)
          ).data.status == 'playing'
          && (
            (
              gameDocumentId == 'board'
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'revealedCoordinates'
                ])
              && request.resource.data.revealedCoordinates
                is list
            )
            ||
            (
              gameDocumentId == 'state'
              && request.resource.data
                .diff(resource.data)
                .affectedKeys()
                .hasOnly([
                  'availableCoordinates',
                  'discardedCoordinates',
                  'remainingCoordinateCount'
                ])
              && request.resource.data.availableCoordinates
                is list
              && request.resource.data.discardedCoordinates
                is list
              && resource.data.remainingCoordinateCount
                is int
              && resource.data.remainingCoordinateCount
                > 0
              && (
                (
                  request.resource.data.remainingCoordinateCount
                    == resource.data.remainingCoordinateCount - 1
                )
                ||
                (
                  request.resource.data.remainingCoordinateCount
                    == resource.data.remainingCoordinateCount
                  && get(
                    participantPath(
                      tableCode,
                      request.auth.uid
                    )
                  ).data.status == 'active'
                  && getAfter(
                    participantPath(
                      tableCode,
                      request.auth.uid
                    )
                  ).data.status == 'left'
                  && isValidCoordinate(
                    get(
                      participantPath(
                        tableCode,
                        request.auth.uid
                      )
                    ).data.currentCoordinate
                  )
                  && getAfter(
                    participantPath(
                      tableCode,
                      request.auth.uid
                    )
                  ).data.currentCoordinate
                    == null
                  && request.resource.data.availableCoordinates
                    == resource.data.availableCoordinates.concat([
                      get(
                        participantPath(
                          tableCode,
                          request.auth.uid
                        )
                      ).data.currentCoordinate
                    ])
                  && request.resource.data.discardedCoordinates
                    == resource.data.discardedCoordinates
                )
                ||
                (
                  isCurrentHost(tableCode)
                  && request.resource.data.remainingCoordinateCount
                    == resource.data.remainingCoordinateCount
                  && resource.data.availableCoordinates
                    .size() > 0
                  && request.resource.data.availableCoordinates
                    == resource.data.availableCoordinates.removeAll([
                      resource.data.availableCoordinates[0]
                    ])
                  && request.resource.data.discardedCoordinates
                    == resource.data.discardedCoordinates
                )
              )
            )
          );

        allow list: if false;

        allow delete: if
          isFinishedTableHost(tableCode);
      }
    }
  }
}